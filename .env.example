# Evoria Mobile — Environment Variables Template
# Salin file ini menjadi .env dan isi nilainya

# Backend API
BASE_URL=https://evoria.life/api/v1

# Midtrans (sandbox)
MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxxxx
MIDTRANS_SNAP_URL=https://app.sandbox.midtrans.com/snap/snap.js

# Google Maps
MAPS_API_KEY=your_google_maps_api_key

# Default map center
DEFAULT_LAT=-0.02633
DEFAULT_LNG=109.34250
DEFAULT_ZOOM=13
